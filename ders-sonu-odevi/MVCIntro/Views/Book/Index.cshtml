@model List<Book>
@{
    // @model List<Book> yazarak, View(books) ile buraya centergönderilen modeli(yani bilgiyi) karşıladık. Karşılarken camelCase şeklinde yazılan model kelimesini kullandık ve buraya gönderilen books modelinin tipini(List<Book>) yazdık. Peki, gönderilen bu bilgiyi karşıladık da; bu bilgi neyin içinde? O da PascalCase şeklinde yazılan Model adlı değişkenin içinde tutuluyor.
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold m-0 text-primary">Kitap Listesi</h2>
        <p class="text-muted m-0 mt-2 small">
            Sistemde kayıtlı kitapları inceleyebilir, yeni kitap ekleyebilirsiniz.
        </p>
    </div>
    <div>
        <a asp-controller="Book" asp-action="Create" class="btn btn-warning shadow-sm rounded-3 d-flex align-items-center">
            <span class="me-2">➕</span>Yeni Kitap Ekle
        </a>
    </div>
</div>

@if(!Model.Any()){
    <div class="card border-0 rounded-4 shadow-sm p-5 text-center bg-info">
        <div class="fs-1 mb-3">📚</div>
        <h4>Kayıtlı kitap yok.</h4>
        <p class="text-muted">
            Eklemek için yukarıdaki butonu kullanabilirsiniz.
        </p>
    </div>
} else {
    <div class="row g-4">
        @foreach(var book in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3">
                <div class="card border-0 rounded-4 shadow p-4 d-flex flex-column justify-content-between premium-card">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="text-uppercase text-info fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.5px; ">@book.Category</span>
                            <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm" style="font-size: 0.85rem;">@book.Price.ToString("C")</span>
                        </div> 
                        <h4 class="fw-bold text-dark mt-2">@book.Title</h4>
                        <p class="text-muted small"><strong>@book.Author</strong></p>
                        <p class="text-muted small">
                            @(string.IsNullOrEmpty(book.Description) ? "Bu kitap için bir açıklama girilmedi." : (book.Description.Length>45 ? book.Description.Substring(0,40) + "..." : book.Description))
                        </p>
                    </div>
                    <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                        <div class="d-flex gap-2">
                            <a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary rounded-pill">Detay</a>
                            <a asp-controller="Book" asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-warning rounded-pill">Düzenle</a>
                        </div>
                        <form asp-controller="Book" asp-action="Delete" asp-route-id="@book.Id" onsubmit="confirm('@book.Title adlı kitabı silmek istediinizden emin misiniz?';)">
                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill">Sil</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}