@model Author
@{
    ViewData["Title"] = "Details";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="premium-card p-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="text-uppercase text-info fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.5px;">Yazar</span>
                <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm fs-6">@Model.Age yaş</span>
            </div>
            <h1 class="fw-bold mb-2">@Model.FirstName @Model.LastName</h1>
            <div class="mb-4">
                <h5 class="fw-bold text-dark">Bilgiler</h5>
                <p class="text-secondary mb-1"><strong>Ad:</strong> @Model.FirstName</p>
                <p class="text-secondary mb-1"><strong>Soyad:</strong> @Model.LastName</p>
                <p class="text-secondary mb-0"><strong>Yaş:</strong> @Model.Age</p>
            </div>
            <div class="pt-4 border-top d-flex gap-3">
                <a asp-controller="Author" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning shadow-sm rounded-3">🖊️ Düzenle</a>
                <a asp-controller="Author" asp-action="Index" class="btn btn-outline-info shadow-sm rounded-3">⬅️ Yazar Listesine Dön</a>
            </div>
        </div>
    </div>
</div>
