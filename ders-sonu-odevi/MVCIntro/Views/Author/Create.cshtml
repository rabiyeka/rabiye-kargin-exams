@model Author
@{
    ViewData["Title"] = "Create";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="premium-card p-5">
            <h2 class="fw-bold mb-3 text-primary">Yeni Yazar Ekle</h2>
            <p class="text-muted small mb-4">
                Yeni yazar eklemek için aşağıdaki formu kullanabilirsiniz.
            </p>
            <form asp-controller="Author" asp-action="Create" method="post" class="d-flex flex-column gap-3">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="mb-3">
                    <label class="form-label" asp-for="FirstName"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="Yazar adını giriniz..." />
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="LastName"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Yazar soyadını giriniz..." />
                </div>
                <div class="mb-3">
                    <label class="form-label" asp-for="Age"></label>
                    <input asp-for="Age" type="number" class="form-control" placeholder="Yaşını giriniz..." />
                </div>
                <div class="d-flex pt-3 gap-3">
                    <button type="submit" class="btn btn-outline-primary">💾 Kaydet</button>
                    <a asp-controller="Author" asp-action="Index" class="btn btn-outline-secondary">⬅️ Listeye Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>
