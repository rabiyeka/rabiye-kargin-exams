@model ProductsIndexViewModel
@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <h1 class="h3 mb-0">Ürünler</h1>
    <form method="get" asp-action="Index" class="d-flex gap-2">
        <select name="categoryId" class="form-select form-select-sm" style="min-width:200px" onchange="this.form.submit()">
            <option value="">Tüm kategoriler</option>
            @foreach (var c in Model.Categories)
            {
                if (Model.SelectedCategoryId == c.Id)
                {
                    <option value="@c.Id" selected>@c.Name (@c.ProductCount)</option>
                }
                else
                {
                    <option value="@c.Id">@c.Name (@c.ProductCount)</option>
                }
            }
        </select>
    </form>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">Bu filtrede ürün bulunamadı.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@product.ImageUrl" class="card-img-top product-card-img" alt="@product.Name" />
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-secondary align-self-start mb-2">@product.CategoryName</span>
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted small flex-grow-1">@(product.Description?.Length > 80 ? product.Description[..80] + "…" : product.Description)</p>
                        <div class="d-flex justify-content-between">
                            <strong class="text-primary">@product.Price.ToString("N2") ₺</strong>
                            <small>Stok: @product.StockQuantity</small>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pb-3">
                        <div class="d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm">Detay</a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="AddToCart" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    <button type="submit" class="btn btn-primary btn-sm w-100">Sepete Ekle</button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm">Sepete eklemek için giriş</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
