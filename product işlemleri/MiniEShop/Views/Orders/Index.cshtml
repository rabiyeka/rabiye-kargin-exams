@model IList<OrderSummaryViewModel>
@{
    ViewData["Title"] = "Siparişlerim";
}

<h1 class="h3 mb-4">Siparişlerim</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">Henüz siparişiniz yok.</div>
}
else
{
    <table class="table table-hover">
        <thead><tr><th>#</th><th>Tarih</th><th>Durum</th><th>Tutar</th><th></th></tr></thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.OrderDate.ToLocalTime().ToString("g")</td>
                    <td><span class="badge bg-secondary">@order.Status</span></td>
                    <td>@order.TotalAmount.ToString("N2") ₺</td>
                    <td><a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">Detay</a></td>
                </tr>
            }
        </tbody>
    </table>
}
