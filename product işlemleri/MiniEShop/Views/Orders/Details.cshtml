@model OrderDetailsViewModel
@{
    ViewData["Title"] = $"Sipariş #{Model.Id}";
}

<h1 class="h3 mb-4">Sipariş #@Model.Id</h1>
<p><strong>Tarih:</strong> @Model.OrderDate.ToLocalTime().ToString("g")</p>
<p><strong>Durum:</strong> <span class="badge bg-secondary">@Model.Status</span></p>

<table class="table">
    <thead><tr><th>Ürün</th><th>Adet</th><th>Birim</th><th>Satır</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Quantity</td>
                <td>@item.UnitPrice.ToString("N2") ₺</td>
                <td>@item.LineTotal.ToString("N2") ₺</td>
            </tr>
        }
    </tbody>
    <tfoot><tr><th colspan="3">Toplam</th><th>@Model.TotalAmount.ToString("N2") ₺</th></tr></tfoot>
</table>
