@model CartIndexViewModel
@{
    ViewData["Title"] = "Sepetim";
}

<h1 class="h3 mb-4">Sepetim</h1>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">Sepetiniz boş.</div>
    <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Alışverişe Başla</a>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th></th><th>Ürün</th><th>Birim</th><th>Miktar</th><th>Toplam</th><th></th></tr></thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><img src="@item.ImageUrl" alt="@item.ProductName" class="cart-thumb rounded" width="50" /></td>
                        <td>@item.ProductName</td>
                        <td>@item.UnitPrice.ToString("N2") ₺</td>
                        <td>
                            <form asp-action="Update" method="post" class="d-flex gap-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control form-control-sm" style="width:70px" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Güncelle</button>
                            </form>
                        </td>
                        <td>@item.LineTotal.ToString("N2") ₺</td>
                        <td>
                            <form asp-action="Remove" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="cartItemId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center">
        <strong>Genel Toplam: @Model.TotalAmount.ToString("N2") ₺ (@Model.TotalItemCount ürün)</strong>
        <form asp-action="Checkout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Siparişi Tamamla</button>
        </form>
    </div>
}
