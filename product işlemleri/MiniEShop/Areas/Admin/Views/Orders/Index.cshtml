@model IList<AdminOrderSummaryViewModel>
@{ ViewData["Title"] = "Siparişler"; var statuses = new[] { "Pending", "Shipped" }; }
<h1 class="h3 mb-4">Siparişler</h1>
<table class="table table-hover bg-white shadow-sm align-middle">
    <thead class="table-light"><tr><th>#</th><th>Tarih</th><th>Müşteri</th><th>Kalem</th><th>Tutar</th><th>Durum</th><th></th></tr></thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Id</td>
                <td>@o.OrderDate.ToLocalTime().ToString("g")</td>
                <td>@o.CustomerEmail</td>
                <td>@o.ItemCount</td>
                <td>@o.TotalAmount.ToString("N2") ₺</td>
                <td><span class="badge bg-secondary">@o.Status</span></td>
                <td>
                    <form asp-action="UpdateStatus" asp-route-id="@o.Id" method="post" class="d-flex gap-1">
                        @Html.AntiForgeryToken()
                        <select name="status" class="form-select form-select-sm">
                            @foreach (var s in statuses) { <option value="@s" selected="@(s == o.Status)">@s</option> }
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary">Kaydet</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
