@model AdminProductFormViewModel
@{ var categories = ViewBag.Categories as IList<AdminCategoryListItemViewModel> ?? []; }
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name"></span></div>
<div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
<div class="row">
    <div class="col-md-6 mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" lang="en" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-md-6 mb-3">
        <label asp-for="StockQuantity" class="form-label"></label>
        <input asp-for="StockQuantity" class="form-control" type="number" step="1" min="0" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>
</div>
<div class="mb-3">
    <label asp-for="CategoryId" class="form-label"></label>
    <select asp-for="CategoryId" class="form-select">
        <option value="">Seçin</option>
        @foreach (var c in categories) { <option value="@c.Id">@c.Name</option> }
    </select>
</div>
<div class="mb-3"><label asp-for="ImageUrl" class="form-label"></label><input asp-for="ImageUrl" class="form-control" /></div>
