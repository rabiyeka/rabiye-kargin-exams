@model AdminCategoryFormViewModel
@{ ViewData["Title"] = "Yeni Kategori"; }
<h1 class="h3 mb-4">Yeni Kategori</h1>
<form asp-action="Create" method="post" class="card shadow-sm"><div class="card-body">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
    <button type="submit" class="btn btn-primary">Kaydet</button>
    <a asp-action="Index" class="btn btn-link">İptal</a>
</div></form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
